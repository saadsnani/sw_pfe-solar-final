# Environment Variables Example
# Copy this file to .env.local and fill in your values

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000

# OpenAI (used by /api/ai/chat)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# Firebase Client SDK (Required for realtime listeners in client hooks)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://your_project_default-rtdb.region.firebasedatabase.app

# Backward-compatible alias used by existing dashboard code
NEXT_PUBLIC_FIREBASE_RTDB_URL=https://your_project_default-rtdb.region.firebasedatabase.app

# Email Service (EmailJS - Optional)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_template_id
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key

# Database (Optional - for production)
# DATABASE_URL=postgresql://...
# MONGODB_URI=mongodb://...

# MongoDB Configuration (Recommended)
# Local MongoDB: mongodb://localhost:27017/solar-monitoring
# MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/solar-monitoring
MONGODB_URI=mongodb://localhost:27017/solar-monitoring
MONGODB_DB=solar-monitoring

# Vercel Storage (Optional - for production data persistence)
# KV_REST_API_URL=...
# KV_REST_API_TOKEN=...

# Development
NODE_ENV=development
